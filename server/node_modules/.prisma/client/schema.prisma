generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(cuid())
  name            String
  email           String              @unique
  createdAt       DateTime            @default(now())
  finances        FinanceEntry[]
  routines        RoutineDefinition[]
  academicCourses AcademicCourse[]
}

model FinanceEntry {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  type      FinanceType
  name      String
  amount    Float
  category  String
  detail    String?
  status    FinanceStatus @default(POSTED)
  createdAt DateTime      @default(now())
  date      DateTime
}

enum FinanceType {
  FIXED
  EXPENSE
  INCOME
}

enum FinanceStatus {
  PENDING
  POSTED
  PAID
}

model AcademicCourse {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  name      String
  shortName String
  moodleId  String?
  grade     String
  note      String?
  tasks     AcademicTask[]
}

model AcademicTask {
  id        String         @id @default(cuid())
  courseId  String
  course    AcademicCourse @relation(fields: [courseId], references: [id])
  title     String
  dueDate   DateTime
  status    AcademicStatus @default(PENDING)
  points    String
  moodleUrl String?
  updatedAt DateTime       @updatedAt
}

enum AcademicStatus {
  PENDING
  DONE
  LATE
}

model RoutineDefinition {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  name        String
  type        RoutineType
  note        String?
  startTime   String
  endTime     String
  startDate   DateTime
  repeat      RepeatPattern
  untilDate   DateTime?
  occurrences RoutineOccurrence[]
}

model RoutineOccurrence {
  id        String            @id @default(cuid())
  routineId String
  routine   RoutineDefinition @relation(fields: [routineId], references: [id])
  date      DateTime
  status    RoutineStatus     @default(PENDING)
  createdAt DateTime          @default(now())
}

enum RoutineType {
  HABIT
  STUDY
  CLASS
  PERSONAL
}

enum RepeatPattern {
  NONE
  DAILY
  WEEKLY
}

enum RoutineStatus {
  PENDING
  DONE
}
